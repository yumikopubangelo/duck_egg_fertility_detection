# ===========================================
# Docker Ignore File
# Exclude files from Docker context
# ===========================================

# ===========================================
# Git & Version Control
# ===========================================
.git
.gitignore
*.md
LICENSE
.env*

# ===========================================
# IDE & OS
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ===========================================
# Python
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.ruff_cache/
.mypy_cache/

# ===========================================
# Virtual Environments
# ===========================================
venv/
ENV/
env/
.venv/

# ===========================================
# Data & Models (Large Files)
# ===========================================
data/raw/*
data/preprocessed/*
data/uploads/*
data/features/*.npy
models/**/*.h5
models/**/*.pth
models/**/*.pkl
models/**/*.npy
results/*
!results/.gitkeep

# ===========================================
# Testing
# ===========================================
tests/
.coverage
htmlcov/

# ===========================================
# Database
# ===========================================
*.db
*.sqlite
*.sqlite3
database/users.db

# ===========================================
# Logs & Temp
# ===========================================
*.log
*.tmp
*.bak
tmp/

# ===========================================
# Notebooks
# ===========================================
*.ipynb_checkpoints
.ipynb

# ===========================================
# Credentials
# ===========================================
.env
.env.local
*.key
*.pem
*.crt
credentials.json
