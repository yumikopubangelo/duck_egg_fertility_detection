# ===========================================
# Duck Egg Fertility Detection - Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!
# ===========================================

# ===========================================
# Application Settings
# ===========================================
APP_NAME=DuckEggFertilityDetection
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production

# ===========================================
# Flask Configuration
# ===========================================
FLASK_APP=web/api/app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# ===========================================
# Database Configuration
# ===========================================
DATABASE_TYPE=sqlite
DATABASE_PATH=database/users.db
DATABASE_URL=sqlite:///database/users.db

# ===========================================
# Web Server
# ===========================================
HOST=0.0.0.0
PORT=5000
UPLOAD_FOLDER=data/uploads
MAX_CONTENT_LENGTH=16777216  # 16MB

# ===========================================
# Model Paths
# ===========================================
MODEL_DIR=models
UNET_MODEL_PATH=models/unet/unet_best.h5
AWC_MODEL_PATH=models/awc/awc_model.pkl

# ===========================================
# Data Paths
# ===========================================
DATA_DIR=data
RAW_DATA_DIR=data/raw
PREPROCESSED_DATA_DIR=data/preprocessed
ANNOTATIONS_DIR=data/annotations
SPLITS_DIR=data/splits

# ===========================================
# Redis (for caching/sessions - optional)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# JWT Authentication (optional)
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24

# ===========================================
# External API Keys (if needed)
# ===========================================
# OPENAI_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
LOG_DIR=results/logs

# ===========================================
# Docker/Deployment
# ===========================================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=duck-egg-fertility-detection
DOCKER_TAG=latest
