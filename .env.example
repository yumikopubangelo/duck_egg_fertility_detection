# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Application Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Database Configuration
DATABASE_URL=postgresql://duck:duckpassword@db:5432/duckdb
DB_PASSWORD=duckpassword

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=./data/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

# Model Configuration
MODEL_PATH=./models/unet/model.pth
AWC_MODEL_PATH=./models/awc/model.pkl

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:5000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance Configuration
WORKERS=4
THREADS_PER_WORKER=2

# Security Headers
SECURE_HEADERS=True
HSTS_MAX_AGE=31536000

# Email Configuration (if needed)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# External API Configuration (if needed)
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key

# Development Configuration
DEBUG_TOOLBAR_ENABLED=False

# Production Configuration
USE_REDIS_CACHE=True
ENABLE_METRICS=True

# Backup Configuration
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Monitoring Configuration
MONITORING_ENABLED=True
METRICS_ENDPOINT=/metrics
ALERTING_ENABLED=True

# Caching Configuration
CACHE_ENABLED=True
CACHE_TIMEOUT=3600
CACHE_SIZE=1000

# Background Tasks Configuration
BACKGROUND_TASKS_ENABLED=True
TASK_BROKER=redis://localhost:6379/0
TASK_RESULT_BACKEND=redis://localhost:6379/0

# External Services Configuration
WEATHER_API_KEY=your-weather-api-key
GEOLOCATION_API_KEY=your-geolocation-api-key

# Feature Flags
ENABLE_NEW_FEATURES=False
BETA_FEATURES=advanced_clustering,real_time_processing

# Performance Configuration
PERFORMANCE_MONITORING=True
PERFORMANCE_METRICS=response_time,throughput,error_rate
PERFORMANCE_THRESHOLDS=response_time:2000,error_rate:0.01

# Maintenance Configuration
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=The application is currently under maintenance. Please try again later.

# Error Handling Configuration
ERROR_HANDLING_ENABLED=True
ERROR_NOTIFICATIONS_ENABLED=True
ERROR_RECOVERY_ENABLED=True

# Security Configuration
SECURITY_HEADERS_ENABLED=True
CSP_ENABLED=True
HSTS_ENABLED=True
X_CONTENT_TYPE_OPTIONS_ENABLED=True
X_FRAME_OPTIONS_ENABLED=True
X_XSS_PROTECTION_ENABLED=True
REFERRER_POLICY_ENABLED=True
PERMISSIONS_POLICY_ENABLED=True

# Compliance Configuration
GDPR_COMPLIANCE_ENABLED=True
CCPA_COMPLIANCE_ENABLED=True
PRIVACY_POLICY_URL=/privacy
TERMS_OF_SERVICE_URL=/terms
COOKIE_POLICY_URL=/cookies
DATA_RETENTION_DAYS=365

# Development Configuration
DEV_MODE=False
DEBUG_MODE=False
HOT_RELOAD=False

# Production Configuration
PROD_MODE=True
PROD_SERVER=gunicorn
PROD_PORT=5000
PROD_HOST=0.0.0.0

# Testing Configuration
TEST_MODE=False
TEST_DATABASE=sqlite:///:memory:
TEST_DATA_DIR=./tests/data
TEST_COVERAGE=True
TEST_PARALLEL=True

# Quality Assurance Configuration
CODE_REVIEW_ENABLED=True
PERFORMANCE_OPTIMIZATION_ENABLED=True
SECURITY_AUDIT_ENABLED=True
FINAL_TESTING_ENABLED=True
